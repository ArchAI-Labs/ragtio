OLLAMA_HOST=http://localhost:11434
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_COLLECTION_NAME=my_experiment   # sovrascrive collection_name in config.yaml
CONFIG_PATH=config.yaml

# LLM provider: "ollama" (default) oppure "openai"
LLM_PROVIDER=ollama

# OpenAI (richiesto solo se LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=    # lascia vuoto per le API ufficiali OpenAI

# Embedder (sovrascrivono i valori in config.yaml)
# EMBEDDER_MODEL=intfloat/multilingual-e5-base
# EMBEDDER_BATCH_SIZE=32
# EMBEDDER_MAX_LENGTH=512
# EMBEDDER_CACHE_DIR=/app/models/fastembed
# EMBEDDER_DIM=768    # override manuale della dimensione vettore

# Custom embedder ONNX via TextEmbedding.add_custom_model()
# Attiva la sezione impostando almeno EMBEDDER_CUSTOM_DIM + una sorgente (HF o URL)
# EMBEDDER_CUSTOM_DIM=384
# EMBEDDER_CUSTOM_POOLING=MEAN          # MEAN | CLS | MAX
# EMBEDDER_CUSTOM_NORMALIZATION=true
# EMBEDDER_CUSTOM_HF_REPO=org/model-name
# EMBEDDER_CUSTOM_URL=                  # alternativa a HF_REPO
# EMBEDDER_CUSTOM_MODEL_FILE=onnx/model.onnx
